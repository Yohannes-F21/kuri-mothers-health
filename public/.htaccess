RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]

# Let Apache serve existing files/directories directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule . - [L]

# SPA fallback: route all other requests through React app.
RewriteRule . /index.html [L]
